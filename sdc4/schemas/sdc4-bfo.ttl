@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdc4: <https://semanticdatacharter.com/ns/sdc4/> .
@prefix obo:  <http://purl.obolibrary.org/obo/> .

<https://semanticdatacharter.com/ns/sdc4-bfo/>
    a owl:Ontology ;
    owl:imports <https://semanticdatacharter.com/ns/sdc4/> ;
    owl:imports <http://purl.obolibrary.org/obo/bfo/2020/bfo.owl> ;
    rdfs:label "SDC4 to BFO Alignment Ontology" ;
    rdfs:comment """Maps SDC4 Reference Model classes to BFO 2020 (ISO/IEC 21838-2:2021).
SDC4 is a meta-level ontology — all classes are information artifact specifications
that map to BFO's GenericallyDependentContinuant.""" ;
    owl:versionInfo "1.0.0" .

# Root: CMC -> GenericallyDependentContinuant (covers ~45 subclasses via transitivity)
sdc4:CMC rdfs:subClassOf obo:BFO_0000031 .

# Non-CMC top-level classes
sdc4:InvlType rdfs:subClassOf obo:BFO_0000031 .
sdc4:InvlUnits rdfs:subClassOf obo:BFO_0000031 .
sdc4:MagnitudeStatus rdfs:subClassOf obo:BFO_0000031 .
